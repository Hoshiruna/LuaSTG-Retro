root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{h,hpp,c,cpp,cc,cxx,inl,ixx}]
indent_style = space
indent_size = 4
tab_width = 4

[CMakeLists.txt]
indent_style = space
indent_size = 4

[*.cmake]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
